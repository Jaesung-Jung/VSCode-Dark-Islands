		},
		".tab:not(.active)": {
			"box-shadow": "inset 0 -1px 0 0 #25262a !important"
		},
		".tab.active:first-child": {
			"box-shadow": "inset -1px 0 0 0 #25262a !important"
		},
		".tab:hover .label-name": {
			"text-shadow": "0 0 5px rgba(255,255,255,0.15) !important",
