			"display": "flex !important",
			"align-items": "center !important"
		},
		".tab .tab-actions .action-label": {
			"border-radius": "50% !important"
		},
		".tab.active": {
			"box-shadow": "inset -1px 0 0 0 #25262a, inset 1px 0 0 0 #25262a !important",
